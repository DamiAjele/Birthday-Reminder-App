# Production env for Vite client build
# Copy to Client/.env.production and set your real API URL before running `npm run build`.
# The value should include the full path to the API base (no trailing slash), e.g.:
# VITE_API_URL=https://api.yourdomain.com/api/v1

VITE_API_URL=https://api.yourdomain.com/api/v1
