## Server environment example
# Copy to `.env` and fill in secrets (do NOT commit `.env`)

# MongoDB connection string
MONGODB_URI=mongodb://127.0.0.1:27017/birthday-reminder-app

# Server port
PORT=4000

# Client origin for CORS (set to your client production URL)
CLIENT_ORIGIN=https://www.yourdomain.com

# Gmail credentials (use App Password or OAuth2 in production)
GMAIL_USER=your@gmail.com
GMAIL_PASS=your_gmail_app_password

# Optional email config
FROM_NAME=CelebrationHub
FROM_EMAIL=your.from@example.com
OFFER_URL=https://example.com/offer
